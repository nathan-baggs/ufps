inline constexpr auto month = @ufps_VERSION_MINOR@;
inline constexpr auto day = @ufps_VERSION_PATCH@;
inline constexpr auto tweak = @ufps_VERSION_TWEAK@;
// clang-format on
}

namespace ufps::config
{

inline constexpr bool logging_enabled = true;
inline constexpr bool log_to_file = true;
inline constexpr bool opengl_debug_enabled = true;
inline constexpr bool use_embedded_resouce_loader = UFPS_USE_EMBEDDED_RESOURCE_LOADER;

}
